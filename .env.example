# Japanese abstract translation/summary runs via the Gemini API (free tier).
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Model used for summarization. Flash-Lite models tend to have more generous
# free-tier rate limits than full Flash models.
GEMINI_MODEL=gemini-3.1-flash-lite

# Gmail account used to send the alert
GMAIL_ADDRESS=you@gmail.com
# Generate at https://myaccount.google.com/apppasswords (requires 2-Step Verification enabled)
GMAIL_APP_PASSWORD=

# Who receives the alert, your keywords, and which journals to watch are
# configured separately in profile.yaml - run `python setup.py` to create it.
